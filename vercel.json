{
  "rewrites": [
    { "source": "/", "destination": "/chloeiq-demo-hub.html" },
    { "source": "/demo", "destination": "/chloeiq-demo-hub.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
